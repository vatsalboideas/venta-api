generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BOSS
  MANAGER
  EMPLOYEE
  INTERN
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum ForecastCategory {
  PIPELINE
  COMMIT
  CLOSED
}

enum LogStatus {
  COLD_LEAD
  MEET_PRESENT
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum LogRevisionType {
  CREATED
  UPDATED
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  password      String
  twoFAEnabled  Boolean   @default(false) @map("2fa_enabled")
  twoFASecret   String?   @map("2fa_secret")
  position      String?
  department    String?
  role          Role
  createdBy     String?   @map("created_by")
  creator       User?     @relation("UserCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdUsers  User[]    @relation("UserCreator")
  ownedBrands   Brand[]   @relation("BrandOwner")
  contactsMade  Contact[] @relation("ContactCreator")
  assignedLogs  Log[]     @relation("LogAssignee")
  assignedLogRevisions LogRevision[] @relation("LogRevisionAssignee")
  logRevisionsEdited   LogRevision[] @relation("LogRevisionEditor")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? @map("deleted_at")

  @@index([createdBy])
  @@index([deletedAt])
  @@map("users")
}

model Department {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("departments")
}

model EmployeeType {
  id        String    @id @default(uuid())
  code      Role      @unique
  label     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("employee_types")
}

model Brand {
  id               String           @id @default(uuid())
  name             String
  industry         String
  priority         Priority
  forecastCategory ForecastCategory @default(PIPELINE) @map("forecast_category")
  expectedRevenue  Decimal          @db.Decimal(14, 2) @map("expected_revenue")
  website          String?
  description      String?
  ownerId          String           @map("owner_id")
  owner            User             @relation("BrandOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  contacts         Contact[]
  logs             Log[]
  logRevisions     LogRevision[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?        @map("deleted_at")

  @@index([ownerId])
  @@index([deletedAt])
  @@map("brands")
}

model Contact {
  id         String   @id @default(uuid())
  brandId    String?  @map("brand_id")
  brand      Brand?   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name       String
  position   String
  email      String
  phone      String
  address    String?
  createdBy  String   @map("created_by")
  creator    User     @relation("ContactCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  logs       Log[]
  logRevisions LogRevision[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime? @map("deleted_at")

  @@index([brandId])
  @@index([createdBy])
  @@index([deletedAt])
  @@map("contacts")
}

model Log {
  id              String    @id @default(uuid())
  title           String
  brandId         String    @map("brand_id")
  brand           Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contactId       String    @map("contact_id")
  contact         Contact   @relation(fields: [contactId], references: [id], onDelete: Restrict)
  status          LogStatus
  priority        Priority
  assignedTo      String    @map("assigned_to")
  assignee        User      @relation("LogAssignee", fields: [assignedTo], references: [id], onDelete: Restrict)
  lastContactDate DateTime  @map("last_contact_date")
  followUpDate    DateTime  @map("follow_up_date")
  meetingDate     DateTime  @map("meeting_date")
  actualRevenue   Decimal?  @db.Decimal(14, 2) @map("actual_revenue")
  notes           String
  revisions       LogRevision[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? @map("deleted_at")

  @@index([brandId])
  @@index([contactId])
  @@index([assignedTo])
  @@index([status])
  @@index([deletedAt])
  @@map("logs")
}

model LogRevision {
  id              String          @id @default(uuid())
  logId           String          @map("log_id")
  log             Log             @relation(fields: [logId], references: [id], onDelete: Cascade)
  revisionType    LogRevisionType @map("revision_type")
  title           String
  brandId         String          @map("brand_id")
  brand           Brand           @relation(fields: [brandId], references: [id], onDelete: Restrict)
  contactId       String          @map("contact_id")
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Restrict)
  status          LogStatus
  priority        Priority
  assignedTo      String          @map("assigned_to")
  assignee        User            @relation("LogRevisionAssignee", fields: [assignedTo], references: [id], onDelete: Restrict)
  lastContactDate DateTime        @map("last_contact_date")
  followUpDate    DateTime        @map("follow_up_date")
  meetingDate     DateTime        @map("meeting_date")
  actualRevenue   Decimal?        @db.Decimal(14, 2) @map("actual_revenue")
  notes           String
  changedBy       String          @map("changed_by")
  changedByUser   User            @relation("LogRevisionEditor", fields: [changedBy], references: [id], onDelete: Restrict)
  changedAt       DateTime        @default(now()) @map("changed_at")
  deletedAt       DateTime?       @map("deleted_at")

  @@index([logId, changedAt])
  @@index([changedBy])
  @@index([deletedAt])
  @@map("log_revisions")
}
